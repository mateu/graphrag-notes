# GraphRAG Notes local inference defaults
# Copy to .env or export these in your shell before running the CLI/tests.

# Use Ollama for both embeddings and extraction
TEI_PROVIDER=ollama
TGI_PROVIDER=ollama

# Local Ollama endpoint
TEI_URL=http://localhost:11434
TGI_URL=http://localhost:11434

# IMPORTANT: this repo expects 1024-dimension embeddings
# bge-m3 matches the schema; nomic-embed-text currently does not in this environment
TEI_MODEL=bge-m3:latest

# Local extraction model
TGI_MODEL=phi4-mini:latest

# Optional extraction tuning
# STRICT_ENTITY_JSON=true
# EXTRACT_MAX_ENTITIES=30
# EXTRACT_MAX_RELATIONSHIPS=15
